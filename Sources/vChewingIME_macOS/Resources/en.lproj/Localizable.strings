"i18n:UserDef.kCandidateNarrationToggleType.description" = "Controls when candidate selections are read aloud (text-to-speech). This allows you highlight selections by ear. If multiple candidates share a pronunciation, the system consults the user-customizable Associated Phrases database to explain each character; the accuracy of the explanation depends on the quality of that database.";
"i18n:UserDef.kCandidateNarrationToggleType.option.0" = "Always Off";
"i18n:UserDef.kCandidateNarrationToggleType.option.1" = "Always On";
"i18n:UserDef.kCandidateNarrationToggleType.option.2" = "Only When VoiceOver is On";
"i18n:UserDef.kCandidateNarrationToggleType.shortTitle" = "Candidate Narration Mode:";
"i18n:UserDef.kCandidateStateJKHLBehavior.description" = "⚠︎ Regarding these specific composition-buffer-cursor-flipping-keys: 1) This will automatically prevent JKHL to be used as candidate keys; 2) They won't work with '%quick' candidates in cassette mode.";
"i18n:UserDef.kCandidateStateJKHLBehavior.option.0" = "Unassigned";
"i18n:UserDef.kCandidateStateJKHLBehavior.option.1" = "JK to move cursor in the composition buffer; HL to flip current candidate row / column";
"i18n:UserDef.kCandidateStateJKHLBehavior.option.2" = "HL to move cursor in the composition buffer; JK to flip current candidate row / column";
"i18n:UserDef.kCandidateStateJKHLBehavior.shortTitle" = "JKHL key behavior in candidate window:";
"i18n:UserDef.kCandidateWindowShowOnlyOneLine.description" = "Tadokoro candidate window shows 4 rows / columns by default, providing similar experiences from Microsoft New Phonetic IME and macOS bult-in Chinese IME (since macOS 10.9). However, for some users who have presbyopia, they prefer giant candidate font sizes, resulting a concern that multiple rows / columns of candidates can make the candidate window looks too big, hence this option. Note that this option will be dismissed if the typing context is vertical, forcing the candidates to be shown in only one row / column. Only one reverse-lookup result can be made available in single row / column mode due to reduced candidate window size.";
"i18n:UserDef.kCandidateWindowShowOnlyOneLine.shortTitle" = "Use only one row / column in candidate window";
"i18n:UserDef.kCassetteEnabled.description" = "Cassette mode is similar to the CIN support of the Yahoo! KeyKey IME, allowing users to use their own CIN tables to implement their stroked-based input schema (e.g. Wubi, Cangjie, Boshiamy, etc.) as a plan-B in vChewing IME. However, since vChewing won't compromise its phonabet input mode experience for this cassette mode, users might not feel comfortable enough comparing to their experiences with RIME (recommended) or OpenVanilla (deprecated).";
"i18n:UserDef.kCassetteEnabled.shortTitle" = "Enable cassette mode, suppressing phonabet input";
"i18n:UserDef.kCassettePath.description" = "Choose your desired cassette file path. Invalid paths will be ignored.\n\n⚠️💀 Avoid iCloud-hosted “Documents” and “Desktop” folders. Their sandbox bookmarks may stop working after reboot or system updates. Move the file to a local folder first if needed.";
"i18n:UserDef.kCassettePath.shortTitle" = "Cassette file path";
"i18n:UserDef.kCheckAbusersOfSecureEventInputAPI.description" = "Such abuse of SecureEventInput API in the background can hinder all 3rd-party input methods from being able to switch to. It is fine to use SecureEventInput for sensitive input fields. However, an app calling EnableSecureEventInput() is responsible to call DisableSecureEventInput() immediately right after the input field loses focus. This situation may also happen if an app is hanging in the background (or working as a helper application in the background) with its SecureEventInput left enabled.";
"i18n:UserDef.kCheckAbusersOfSecureEventInputAPI.shortTitle" = "Actively check those processes abusing the SecureEventInput API";
"i18n:UserDef.kCheckUpdateAutomatically.shortTitle" = "Check for updates automatically";
"i18n:UserDef.kChineseConversionEnabled.shortTitle" = "Auto-convert traditional Chinese glyphs to KangXi characters";
"i18n:UserDef.kChooseCandidateUsingSpace.description" = "If disabled, this will insert space instead.";
"i18n:UserDef.kChooseCandidateUsingSpace.shortTitle" = "Enable Space key for calling candidate window";
"i18n:UserDef.kClassicHaninKeyboardSymbolModeShortcutEnabled.shortTitle" = "Also use “\\” or “¥” key for Hanin Keyboard Symbol Input";
"i18n:UserDef.kCNS11643Enabled.shortTitle" = "Enable CNS11643 Support (2026-05-06)";
"i18n:UserDef.kConsolidateContextOnCandidateSelection.description" = "For example: When typing “章太炎” and you want to override the “太” with “泰”, and the raw operation index range [1,2) which bounds are cutting the current node “章太炎” in range [0,3). If having lack of the pre-consolidation process, this word will become something like “張泰言” after the candidate selection. Only if we enable this consolidation, this word will become “章泰炎” which is the expected result that the context is kept as-is.";
"i18n:UserDef.kConsolidateContextOnCandidateSelection.shortTitle" = "Consolidate the context on confirming candidate selection";
"i18n:UserDef.kCurrencyNumeralsEnabled.shortTitle" = "Enable currency numerals output";
"i18n:UserDef.kCursorPlacementAfterSelectingCandidate.description" = "This defines the cursor position after a candidate is confirmed through the candidate window. Note that the Pre-Candidate-Window Cursor Position is the cursor position snapshotted right before the candidate window shows up. If you choose to let it move a step front, the step length may vary, depending on your preferred candidate cursor selection style.";
"i18n:UserDef.kCursorPlacementAfterSelectingCandidate.option.0" = "No Adjustments";
"i18n:UserDef.kCursorPlacementAfterSelectingCandidate.option.1" = "A Step Front";
"i18n:UserDef.kCursorPlacementAfterSelectingCandidate.option.2" = "Restore Pre-Candidate-Window Cursor Position";
"i18n:UserDef.kCursorPlacementAfterSelectingCandidate.shortTitle" = "Post-Candidate Cursor Position:";
"i18n:UserDef.kDisableSegmentedThickUnderlineInMarkingModeForManagedClients.description" = "Some clients with web-based front UI may have issues rendering segmented thick underlines drawn by their implemented “setMarkedText()”. This option stops the input method from delivering segmented thick underlines to “client().setMarkedText()”. Note that segmented thick underlines are only used in marking mode, unless the client itself misimplements the IMKTextInput method “setMarkedText()”. This option only affects the inline composition buffer.";
"i18n:UserDef.kDisableSegmentedThickUnderlineInMarkingModeForManagedClients.shortTitle" = "Disable segmented thick underline in marking mode for managed clients";
"i18n:UserDef.kDodgeInvalidEdgeCandidateCursorPosition.shortTitle" = "Dodge Invalid Edge Candidate Cursor Position";
"i18n:UserDef.kEnableCandidateWindowAnimation.shortTitle" = "Enable animation for candidate window movement/resize";
"i18n:UserDef.kEnableMouseScrollingForTDKCandidatesCocoa.shortTitle" = "Enable mouse wheel support for Tadokoro Candidate Window";
"i18n:UserDef.kEnforceETenDOSCandidateSequence.description" = "This option is provided for users who prefer the ETen Chinese DOS candidate ordering. Many such users developed their ordering intuition while using the ETen Chinese DOS input method and wish to use the same order here. Note: the select-candidate-per-character mode always follows this ordering and is not affected by this setting.";
"i18n:UserDef.kEnforceETenDOSCandidateSequence.shortTitle" = "Enforce Eten DOS Sequence on all single-kanji candidates";
"i18n:UserDef.kEscToCleanInputBuffer.description" = "If unchecked, the ESC key will try cleaning the unfinished readings / strokes first, and will commit the current composition buffer if there's no unfinished readings / strokes.";
"i18n:UserDef.kEscToCleanInputBuffer.shortTitle" = "Use ESC key to clear the entire input buffer";
"i18n:UserDef.kFetchSuggestionsFromPerceptionOverrideModel.description" = "The user override model only possesses memories temporarily. Each memory record gradually becomes ineffective within approximately less than 6 days. You can erase all memory records through the input method menu.";
"i18n:UserDef.kFetchSuggestionsFromPerceptionOverrideModel.shortTitle" = "Applying typing suggestions from perception override model";
"i18n:UserDef.kFilterFactoryKanjisOfNonCurrentInputMode.description" = "When enabled, single-kanji candidates that are exclusive to the opposite script mode (e.g. simplified-only characters in Traditional mode) will be removed from the candidate window. Characters supported by EtenDOS and CNS are never filtered. Note: The filtering scope is limited to characters within Unicode 1.0.1 (the EtenDOS character set); characters introduced in later Unicode versions are not covered.";
"i18n:UserDef.kFilterFactoryKanjisOfNonCurrentInputMode.shortTitle" = "Filter out kanji candidates unrelated to the current input mode";
"i18n:UserDef.kFilterNonCNSReadingsForCHTInput.description" = "For single-kanji candidates, non-conforming results will be demoted to the end of the candidate list instead of being completely removed.";
"i18n:UserDef.kFilterNonCNSReadingsForCHTInput.shortTitle" = "Filter Non-CNS11643 factory readings (CHT input only)";
"i18n:UserDef.kForceCassetteChineseConversion.description" = "This conversion only affects the cassette module, converting typed contents to either Simplified Chinese or Traditional Chinese in accordance with this setting and your current input mode.";
"i18n:UserDef.kForceCassetteChineseConversion.option.0" = "Disable forced conversion for cassette outputs";
"i18n:UserDef.kForceCassetteChineseConversion.option.1" = "Enforce conversion in both input modes";
"i18n:UserDef.kForceCassetteChineseConversion.option.2" = "Only enforce conversion in Simplified Chinese mode";
"i18n:UserDef.kForceCassetteChineseConversion.option.3" = "Only enforce conversion in Traditional Chinese mode";
"i18n:UserDef.kForceCassetteChineseConversion.shortTitle" = "Chinese Conversion:";
"i18n:UserDef.kHalfWidthPunctuationEnabled.shortTitle" = "Enable half-width punctuations";
"i18n:UserDef.kHardenVerticalPunctuations.description" = "⚠︎ This feature is useful ONLY WHEN the font you are using doesn't support dynamic vertical punctuations. However, typed vertical punctuations will always shown as vertical punctuations EVEN IF your editor has changed the typing direction to horizontal.";
"i18n:UserDef.kHardenVerticalPunctuations.shortTitle" = "Harden vertical punctuations during vertical typing (not recommended)";
"i18n:UserDef.kInlineDumpPinyinInLieuOfZhuyin.description" = "Contents committed by Command+Option+Ctrl+Enter may vary depending on related behavior settings.";
"i18n:UserDef.kInlineDumpPinyinInLieuOfZhuyin.shortTitle" = "Commit Hanyu-Pinyin instead on Ctrl(+Option)+Command+Enter";
"i18n:UserDef.kIsDebugModeEnabled.shortTitle" = "Debug Mode";
"i18n:UserDef.kKeepReadingUponCompositionError.shortTitle" = "Allow backspace-editing miscomposed readings";
"i18n:UserDef.kKeyboardParser.description" = "Choose the phonetic layout for the Mandarin parser. Pinyin options are also available here. In Pinyin input mode, the compositor engine may cap candidate assembly to 4 readings when there are incompletely specified reading units (for example, missing tone marks) within the current +/-10 scan range. This cap is not applied when every reading within that +/-10 range is a fully specified, tone-marked spelling.";
"i18n:UserDef.kKeyboardParser.shortTitle" = "Phonetic Parser:";
"i18n:UserDef.kMinCellWidthForHorizontalMatrix.option.0" = "2 Kanjis";
"i18n:UserDef.kMinCellWidthForHorizontalMatrix.option.1" = "2 Emojis (Wider)";
"i18n:UserDef.kMinCellWidthForHorizontalMatrix.shortTitle" = "Minimum cell width for horizontal matrix:";
"i18n:UserDef.kMixedAlphanumericalEnabled.description" = "This feature is designed for users who are already accustomed to the typing experience offered by a certain Smart Input software from a PC vendor. It treats parser-covered ASCII keys as provisional phonetic input first, then falls back to raw ASCII when the sequence is no longer a pronounceable reading. This feature is unavailable in pinyin typing mode (that is, when the phonabet parser uses any pinyin layout) and in cassette mode. If this typing fallback is enabled, you may also want to check the Dictionary settings page to decide whether to filter out certain factory dictionary query results that could affect your typing experience. If you need half-width punctuation input, please toggle the Half-Width Phuctuation Mode to ON.";
"i18n:UserDef.kMixedAlphanumericalEnabled.shortTitle" = "Enable mixed Chinese-English typing fallback";
"i18n:UserDef.kNumPadCharInputBehavior.description" = "Choose the behavior of numeric pad inputs.";
"i18n:UserDef.kNumPadCharInputBehavior.option.0" = "Always directly commit half-width chars";
"i18n:UserDef.kNumPadCharInputBehavior.option.1" = "Always directly commit full-width chars";
"i18n:UserDef.kNumPadCharInputBehavior.option.2" = "Insert into composition buffer (half-width)";
"i18n:UserDef.kNumPadCharInputBehavior.option.3" = "Insert into composition buffer (full-width)";
"i18n:UserDef.kNumPadCharInputBehavior.option.4" = "Directly commit half-width chars only if the compositor is empty";
"i18n:UserDef.kNumPadCharInputBehavior.option.5" = "Directly commit full-width chars only if the compositor is empty";
"i18n:UserDef.kNumPadCharInputBehavior.shortTitle" = "Numeric Pad:";
"i18n:UserDef.kPhraseEditorAutoReloadExternalModifications.shortTitle" = "This editor only: Auto-reload modifications happened outside of this editor";
"i18n:UserDef.kPhraseReplacementEnabled.description" = "This will batch-replace specified candidates.";
"i18n:UserDef.kPhraseReplacementEnabled.shortTitle" = "Enable phrase replacement table";
"i18n:UserDef.kReadingNarrationCoverage.description" = "This reads your typed phonabets aloud. Only works with non-cassette Mode.";
"i18n:UserDef.kReadingNarrationCoverage.option.0" = "Do not narrate";
"i18n:UserDef.kReadingNarrationCoverage.option.1" = "Only when combined by intonation";
"i18n:UserDef.kReadingNarrationCoverage.option.2" = "All changes in reading composer";
"i18n:UserDef.kReadingNarrationCoverage.shortTitle" = "Reading composer contents to narrate";
"i18n:UserDef.kReducePOMLifetimeToNoMoreThan12Hours.description" = "When enabled, the perception override model's forgetting cycle will be reduced from approximately one week to within 12 hours, clearing infrequently used memory records more quickly.";
"i18n:UserDef.kReducePOMLifetimeToNoMoreThan12Hours.shortTitle" = "Enable rapid forgetting mode";
"i18n:UserDef.kReflectBPMFVSInCompositionBuffer.description" = "Only takes effect when Command+Option+Ctrl+Enter is set to commit ButKo BPMFVS annotation. When enabled, the composition buffer and candidate preview show the projected ButKo BPMFVS form so the visible glyphs stay aligned with the special-commit result.";
"i18n:UserDef.kReflectBPMFVSInCompositionBuffer.shortTitle" = "Reflect ButKo BPMFVS in composition buffer";
"i18n:UserDef.kReplaceSymbolMenuNodeWithUserSuppliedData.description" = "Single-tapping [Symbol Menu Key] without modifier keys triggers the hierarchical symbol menu. By enabling this feature, this symbol menu will represent only the contents supplied by `symbols.dat` which is optionally suppliable in the user dictionary folder, conforming to LibChewing symbol data file format. If toggling this off, these user-supplied contents will instead become the trailing subnode of the root node of the factory symbol menu contents.";
"i18n:UserDef.kReplaceSymbolMenuNodeWithUserSuppliedData.shortTitle" = "Replace the entire hierarchical symbol menu contents with user-supplied `symbols.dat` data";
"i18n:UserDef.kRespectClientAccentColor.description" = "This will force the highlighted candidate background color to follow the accent color of the current client app, behaving like what macOS built-in input methods do. If it doesn't have one (or the system accent color is set with a non-default value), then the system accent color will be used instead. Note that this won't be effective if either JIS or KangXi conversion mode is enabled.";
"i18n:UserDef.kRespectClientAccentColor.shortTitle" = "Respect accent colors of the client app and the system";
"i18n:UserDef.kRomanNumeralOutputFormat.description" = "Roman Numeral Input Mode can be switched to while using [Opt]+[Symbol Menu Key] to revolve the current typing method, supporting integers in the closed range of [1, 3999]. After a successful or failed input, this mode will be automatically switched off.";
